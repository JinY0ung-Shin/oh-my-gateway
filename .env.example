# Authentication Method (optional - explicit selection)
# Set this to override auto-detection. Values: cli, api_key
# If not set, auto-detects based on available env vars (ANTHROPIC_AUTH_TOKEN, etc.)
# CLAUDE_AUTH_METHOD=cli

# Claude Code Environment Variables
# These are passed through to the Claude Code CLI / Agent SDK
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_AUTH_TOKEN=your-auth-token
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-5-20250929
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5-20250929
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001


# API Configuration
# If API_KEY is not set, server will prompt for interactive API key protection on startup
# Leave commented out to enable interactive prompt, or uncomment to use a fixed API key
# API_KEY=your-optional-api-key-here

# Working directory for Claude Code SDK (defaults to isolated temp dir if not set)
CLAUDE_CWD=./working_dir

# Per-user workspace isolation
# Base directory for user workspaces ({dir}/{user}/ per user)
# Falls back to CLAUDE_CWD if empty. If both empty, uses temp dir.
# USER_WORKSPACES_DIR=/data/workspaces

# Maximum length of tool result content in streaming output (default: 2000 chars)
TOOL_RESULT_MAX_LENGTH=200

# Server Configuration
PORT=8000
# Host binding address - use 127.0.0.1 for local-only access, 0.0.0.0 for all interfaces
# CLAUDE_WRAPPER_HOST=0.0.0.0
# Maximum request body size in bytes (default: 10MB)
# MAX_REQUEST_SIZE=10485760

# Timeout Configuration (milliseconds)
MAX_TIMEOUT=600000

# CORS Configuration
CORS_ORIGINS=["*"]

# Model Configuration
# Default Claude model to use when none specified in request
DEFAULT_MODEL=sonnet

# SDK Configuration
# Maximum conversation turns per request
# DEFAULT_MAX_TURNS=10

# ============================================================================
# System Prompt Configuration
# ============================================================================
# Path to a text file containing a custom system prompt.
# When set, replaces the claude_code preset entirely.
# Can also be configured at runtime via /admin UI.
# SYSTEM_PROMPT_FILE=docs/claude-code-system-prompt-reference.md

# Placeholder values resolved in system prompt {{PLACEHOLDER}} tokens.
# These are substituted when the prompt file is loaded.
# PROMPT_LANGUAGE=Korean
# PROMPT_MEMORY_PATH=/path/to/memory/
#
# Auto-detected placeholders (no env var needed):
#   {{WORKING_DIRECTORY}} ← CLAUDE_CWD (see above)
#   {{PLATFORM}}          ← sys.platform (auto)
#   {{SHELL}}             ← $SHELL (auto)
#   {{OS_VERSION}}        ← platform.platform() (auto)

# Thinking Mode: adaptive (default, recommended), enabled (fixed budget), disabled
# THINKING_MODE=adaptive
# Budget tokens for "enabled" mode (ignored for adaptive/disabled)
# THINKING_BUDGET_TOKENS=10000

# Task budget (tokens) — global default for all requests.
# The model paces tool use and wraps up before exceeding this limit.
# Per-request task_budget in the API body overrides this value.
# TASK_BUDGET=

# Token-level streaming (true=stream individual tokens, false=wait for complete messages)
# TOKEN_STREAMING=true

# Disallowed Subagent Types (comma-separated)
# Block specific built-in subagent types via Agent(type) syntax
# Available types: general-purpose, Explore, Plan, statusline-setup
# DISALLOWED_SUBAGENT_TYPES=statusline-setup

# Subagent Streaming Visibility
# Control which subagent outputs are forwarded to the client during streaming.
# SUBAGENT_STREAM_TEXT: Forward subagent text deltas (default: false — only final summary)
# SUBAGENT_STREAM_TOOL_BLOCKS: Forward subagent tool_use/tool_result blocks (default: true)
# SUBAGENT_STREAM_PROGRESS: Forward task_started/progress/notification events (default: true)
# SUBAGENT_STREAM_TEXT=false
# SUBAGENT_STREAM_TOOL_BLOCKS=true
# SUBAGENT_STREAM_PROGRESS=true

# Bash Sandbox (OS-level process isolation for Bash tool execution)
# Tri-state: unset = respect project-level settings, true = force enable, false = force disable
# Only affects Bash commands; Read/Edit/Write access is controlled by SDK permission rules.
# Requires macOS (Seatbelt) or Linux (bubblewrap). Not supported on Windows.
# CLAUDE_SANDBOX_ENABLED=true
# Auto-approve bash commands when sandboxed (default: true)
# CLAUDE_SANDBOX_AUTO_ALLOW_BASH=true
# Commands that bypass the sandbox (comma-separated, default: none)
# CLAUDE_SANDBOX_EXCLUDED_COMMANDS=
# Allow model to request unsandboxed execution via dangerouslyDisableSandbox (default: false)
# CLAUDE_SANDBOX_ALLOW_UNSANDBOXED=false
# Allow binding to local network ports inside sandbox (default: false)
# CLAUDE_SANDBOX_NETWORK_ALLOW_LOCAL=false
# Enable weaker sandbox for unprivileged Docker containers on Linux (default: false)
# CLAUDE_SANDBOX_WEAKER_NESTED=false

# SSE keepalive interval in seconds (prevents connection drops during long SDK operations)
# Set to 0 to disable. Default: 15
# SSE_KEEPALIVE_INTERVAL=15

# Session Management
# SESSION_CLEANUP_INTERVAL_MINUTES=5
# SESSION_MAX_AGE_MINUTES=60

# AskUserQuestion hook timeout (seconds).
# If the client does not respond within this window the hook denies the
# tool call and the SDK resumes. Default: 300 (5 minutes).
# ASK_USER_TIMEOUT_SECONDS=300

# MCP Server Configuration
# Path to MCP config JSON file or inline JSON string
# Format: {"mcpServers": {"name": {"type": "stdio|sse|http", ...}}}
# MCP_CONFIG={"mcpServers": {"filesystem": {"type": "stdio", "command": "npx", "args": ["-y", "@modelcontextprotocol/server-filesystem", "/workspace"]}}}
# MCP_CONFIG=/path/to/mcp-config.json

# Metadata env var passthrough (comma-separated allowlist)
# Only metadata keys listed here are forwarded as env vars to the Claude subprocess.
# Callers send these via the "metadata" field in /v1/responses requests.
# Example: a2a-agent sends metadata={"THREAD_ID": "abc"} on every turn.
METADATA_ENV_ALLOWLIST=THREAD_ID,ORCHESTRATOR_URL

# Debugging
# DEBUG_MODE=false
# VERBOSE=false

# ============================================================================
# Admin UI Configuration
# ============================================================================
# Web-based admin dashboard at /admin for managing workspace files,
# viewing config, monitoring sessions, and checking backend status.

# Admin API key (REQUIRED — server will not start without it)
# This is independent from the gateway API_KEY — admin is a higher-privilege surface.
# ADMIN_API_KEY=your-secure-admin-key-here

# Admin session TTL in seconds (default: 3600 = 1 hour)
# ADMIN_SESSION_TTL=3600

# Set to true if serving behind HTTPS to mark session cookie as Secure
# ADMIN_COOKIE_SECURE=false

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_DEBUG_PER_MINUTE=2
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_SESSION_PER_MINUTE=15
RATE_LIMIT_HEALTH_PER_MINUTE=30
RATE_LIMIT_RESPONSES_PER_MINUTE=10

# ============================================================================
# Docker Build-Time Options (consumed by `docker compose build`, not runtime)
# ============================================================================
# These are NOT read by the server at runtime. docker-compose.yml picks them
# up at build time via build.args and passes them to `uv sync` inside the image.
# Leave unset on public networks.

# Private PyPI mirror (e.g. internal Nexus). When set, `uv sync` fetches
# packages from this index instead of pypi.org.
# UV_INDEX_URL=https://nexus.example.com/repository/pypi/simple/

# Additional index, searched after UV_INDEX_URL.
# UV_EXTRA_INDEX_URL=https://extra-index.example.com/simple/

# Relaxes uv.lock's URL check so lockfile entries (pypi.org) can resolve
# against the mirror when the mirror serves identical wheels. Only set
# this if `uv sync` fails with hash/URL mismatch errors.
# UV_INDEX_STRATEGY=unsafe-best-match

# HTTP(S) proxy for the build (apt-get, uv sync, image pulls).
# Docker treats these as predefined proxy ARGs — not baked into image history.
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,.example.com

# ---------------------------------------------------------------------------
# Usage logging (optional)
# ---------------------------------------------------------------------------
# When USAGE_LOG_DB_URL is set, the gateway writes one row per /v1/responses
# turn into the configured database (see docker-compose `logging` profile
# for a ready-to-run MySQL sidecar).  Leave unset to disable.
#
# URL is a SQLAlchemy URL.  These shorthands are auto-mapped to the async
# driver (driver must be installed):
#   mysql://...       -> mysql+aiomysql://...      (aiomysql, bundled)
#   sqlite://...      -> sqlite+aiosqlite://...    (install aiosqlite)
# USAGE_LOG_DB_URL=mysql://gateway:gateway@gateway-log:3306/gateway_log
# USAGE_LOG_DB_URL=sqlite+aiosqlite:///./data/gateway_log.sqlite

# Credentials used by the `gateway-log` MySQL sidecar in docker-compose.yml.
# Override these in production deployments.
# GATEWAY_LOG_MYSQL_ROOT_PASSWORD=gateway_root
# GATEWAY_LOG_MYSQL_USER=gateway
# GATEWAY_LOG_MYSQL_PASSWORD=gateway
# GATEWAY_LOG_MYSQL_DATABASE=gateway_log
# GATEWAY_LOG_PORT=3306
